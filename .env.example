# ================================
# SkinBase Environment Variables
# ================================
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git!

# ── Supabase ─────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get from: Stripe Dashboard → Products → SkinBase Pro → Pricing
NEXT_PUBLIC_STRIPE_PRICE_ID_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_ANNUAL=price_...

# Get from: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic (Claude Vision) ───────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Replicate AI ─────────────────────────────────────
# Get from: https://replicate.com → Account → API tokens
REPLICATE_API_TOKEN=r8_...

# ── Amazon Associates ────────────────────────────────
# Get from: https://affiliate-program.amazon.com
# Your tracking ID looks like: yourname-20
# Currently using placeholder - will be replaced with real tag via env variable
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=MY_ASSOCIATE_TAG

# ── App Config ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
